<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.teaching.module.edu_course.mapper.EduCourseMapper">

    <sql id="whereCondition">
        <where>
            <if test="entity.id != null">
                AND eduCourse.id = #{entity.id}
            </if>
            <if test="entity.courseName != null and entity.courseName != ''">
                AND eduCourse.course_name LIKE CONCAT('%', #{entity.courseName}, '%')
            </if>
            <if test="entity.difficultyLevel != null">
                AND eduCourse.difficulty_level = #{entity.difficultyLevel}
            </if>
            <if test="entity.auditStatus != null and entity.auditStatus != -1">
                AND eduCourse.audit_status = #{entity.auditStatus}
            </if>
            <if test="entity.auditStatus != null and entity.auditStatus == -1">
                AND (eduCourse.audit_status IS NULL OR eduCourse.audit_status != 1)
            </if>
            <if test="entity.status != null">
                AND eduCourse.status = #{entity.status}
            </if>
            <if test="entity.realName != null and entity.realName != ''">
                AND eduUser.real_name LIKE CONCAT('%', #{entity.realName}, '%')
            </if>
            <if test="entity.teacherId != null">
                AND eduCourse.teacher_id = #{entity.teacherId}
            </if>
        </where>
    </sql>

    <!-- 分页查询 -->
    <select id="pageQuery" resultType="com.edu.teaching.module.edu_course.entity.EduCourse">
        SELECT eduCourse.*
        , eduUser.real_name AS realName
        FROM edu_course eduCourse
        LEFT JOIN edu_user eduUser ON eduCourse.teacher_id = eduUser.id
        <include refid="whereCondition"/>
        ORDER BY eduCourse.create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 查询总数 -->
    <select id="countQuery" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM edu_course eduCourse
        LEFT JOIN edu_user eduUser ON eduCourse.teacher_id = eduUser.id
        <include refid="whereCondition"/>
    </select>

    <!-- 列表查询（不分页） -->
    <select id="listQuery" resultType="com.edu.teaching.module.edu_course.entity.EduCourse">
        SELECT eduCourse.*
        , eduUser.real_name AS realName
        FROM edu_course eduCourse
        LEFT JOIN edu_user eduUser ON eduCourse.teacher_id = eduUser.id
        <include refid="whereCondition"/>
        ORDER BY eduCourse.create_time DESC
    </select>

    <!-- 根据ID查询 -->
    <select id="getById" resultType="com.edu.teaching.module.edu_course.entity.EduCourse">
        SELECT eduCourse.*
        , eduUser.real_name AS realName
        FROM edu_course eduCourse
        LEFT JOIN edu_user eduUser ON eduCourse.teacher_id = eduUser.id
        WHERE eduCourse.id = #{id}
    </select>

</mapper>
