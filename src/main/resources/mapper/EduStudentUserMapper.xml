<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.teaching.module.edu_student_user.mapper.EduStudentUserMapper">

    <sql id="whereCondition">
        <where>
            <if test="entity.id != null">
                AND eduStudentUser.id = #{entity.id}
            </if>
            <if test="entity.username != null and entity.username != ''">
                AND eduStudentUser.username LIKE CONCAT('%', #{entity.username}, '%')
            </if>
            <if test="entity.realName != null and entity.realName != ''">
                AND eduStudentUser.real_name LIKE CONCAT('%', #{entity.realName}, '%')
            </if>
            <if test="entity.phone != null and entity.phone != ''">
                AND eduStudentUser.phone LIKE CONCAT('%', #{entity.phone}, '%')
            </if>
            <if test="entity.grade != null and entity.grade != ''">
                AND eduStudentUser.grade LIKE CONCAT('%', #{entity.grade}, '%')
            </if>
            <if test="entity.major != null and entity.major != ''">
                AND eduStudentUser.major LIKE CONCAT('%', #{entity.major}, '%')
            </if>
            <if test="entity.status != null">
                AND eduStudentUser.status = #{entity.status}
            </if>
        </where>
    </sql>

    <!-- 分页查询 -->
    <select id="pageQuery" resultType="com.edu.teaching.module.edu_student_user.entity.EduStudentUser">
        SELECT eduStudentUser.*
        FROM edu_student_user eduStudentUser
        <include refid="whereCondition"/>
        ORDER BY eduStudentUser.create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 查询总数 -->
    <select id="countQuery" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM edu_student_user eduStudentUser
        <include refid="whereCondition"/>
    </select>

    <!-- 列表查询（不分页） -->
    <select id="listQuery" resultType="com.edu.teaching.module.edu_student_user.entity.EduStudentUser">
        SELECT eduStudentUser.*
        FROM edu_student_user eduStudentUser
        <include refid="whereCondition"/>
        ORDER BY eduStudentUser.create_time DESC
    </select>

    <!-- 根据ID查询 -->
    <select id="getById" resultType="com.edu.teaching.module.edu_student_user.entity.EduStudentUser">
        SELECT eduStudentUser.*
        FROM edu_student_user eduStudentUser
        WHERE eduStudentUser.id = #{id}
    </select>

</mapper>
