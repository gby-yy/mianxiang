<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.teaching.module.edu_user.mapper.EduUserMapper">

    <sql id="whereCondition">
        <where>
            <if test="entity.id != null">
                AND eduUser.id = #{entity.id}
            </if>
            <if test="entity.username != null and entity.username != ''">
                AND eduUser.username LIKE CONCAT('%', #{entity.username}, '%')
            </if>
            <if test="entity.realName != null and entity.realName != ''">
                AND eduUser.real_name LIKE CONCAT('%', #{entity.realName}, '%')
            </if>
            <if test="entity.roleType != null and entity.roleType != ''">
                AND eduUser.role_type = #{entity.roleType}
            </if>
            <if test="entity.phone != null and entity.phone != ''">
                AND eduUser.phone LIKE CONCAT('%', #{entity.phone}, '%')
            </if>
            <if test="entity.gender != null">
                AND eduUser.gender = #{entity.gender}
            </if>
            <if test="entity.titleLevel != null">
                AND eduUser.title_level = #{entity.titleLevel}
            </if>
            <if test="entity.status != null">
                AND eduUser.status = #{entity.status}
            </if>
        </where>
    </sql>

    <!-- 分页查询 -->
    <select id="pageQuery" resultType="com.edu.teaching.module.edu_user.entity.EduUser">
        SELECT eduUser.*
        FROM edu_user eduUser
        <include refid="whereCondition"/>
        ORDER BY eduUser.create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 查询总数 -->
    <select id="countQuery" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM edu_user eduUser
        <include refid="whereCondition"/>
    </select>

    <!-- 列表查询（不分页） -->
    <select id="listQuery" resultType="com.edu.teaching.module.edu_user.entity.EduUser">
        SELECT eduUser.*
        FROM edu_user eduUser
        <include refid="whereCondition"/>
        ORDER BY eduUser.create_time DESC
    </select>

    <!-- 根据ID查询 -->
    <select id="getById" resultType="com.edu.teaching.module.edu_user.entity.EduUser">
        SELECT eduUser.*
        FROM edu_user eduUser
        WHERE eduUser.id = #{id}
    </select>

</mapper>
