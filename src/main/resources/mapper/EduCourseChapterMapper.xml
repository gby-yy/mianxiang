<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.teaching.module.edu_course_chapter.mapper.EduCourseChapterMapper">

    <sql id="whereCondition">
        <where>
            <if test="entity.id != null">
                AND eduCourseChapter.id = #{entity.id}
            </if>
            <if test="entity.courseId != null">
                AND eduCourseChapter.course_id = #{entity.courseId}
            </if>
            <if test="entity.chapterName != null and entity.chapterName != ''">
                AND eduCourseChapter.chapter_name LIKE CONCAT('%', #{entity.chapterName}, '%')
            </if>
            <if test="entity.chapterType != null">
                AND eduCourseChapter.chapter_type = #{entity.chapterType}
            </if>
            <if test="entity.difficultyLevel != null">
                AND eduCourseChapter.difficulty_level = #{entity.difficultyLevel}
            </if>
            <if test="entity.courseName != null and entity.courseName != ''">
                AND eduCourse.course_name LIKE CONCAT('%', #{entity.courseName}, '%')
            </if>
        </where>
    </sql>

    <!-- 分页查询 -->
    <select id="pageQuery" resultType="com.edu.teaching.module.edu_course_chapter.entity.EduCourseChapter">
        SELECT eduCourseChapter.*
        , eduCourse.course_name AS courseName
        FROM edu_course_chapter eduCourseChapter
        LEFT JOIN edu_course eduCourse ON eduCourseChapter.course_id = eduCourse.id
        <include refid="whereCondition"/>
        ORDER BY eduCourseChapter.create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 查询总数 -->
    <select id="countQuery" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM edu_course_chapter eduCourseChapter
        LEFT JOIN edu_course eduCourse ON eduCourseChapter.course_id = eduCourse.id
        <include refid="whereCondition"/>
    </select>

    <!-- 列表查询（不分页） -->
    <select id="listQuery" resultType="com.edu.teaching.module.edu_course_chapter.entity.EduCourseChapter">
        SELECT eduCourseChapter.*
        , eduCourse.course_name AS courseName
        FROM edu_course_chapter eduCourseChapter
        LEFT JOIN edu_course eduCourse ON eduCourseChapter.course_id = eduCourse.id
        <include refid="whereCondition"/>
        ORDER BY eduCourseChapter.create_time DESC
    </select>

    <!-- 根据ID查询 -->
    <select id="getById" resultType="com.edu.teaching.module.edu_course_chapter.entity.EduCourseChapter">
        SELECT eduCourseChapter.*
        , eduCourse.course_name AS courseName
        FROM edu_course_chapter eduCourseChapter
        LEFT JOIN edu_course eduCourse ON eduCourseChapter.course_id = eduCourse.id
        WHERE eduCourseChapter.id = #{id}
    </select>

</mapper>
